# Puerto del servidor
PORT=3000

# SMTP — Configuración de correo saliente
# Para Gmail usar: smtp.gmail.com / 587 / SMTP_SECURE=false
# Para Gmail con SSL: smtp.gmail.com / 465 / SMTP_SECURE=true
# Para Zoho: smtp.zoho.com / 587
# Para Brevo (Sendinblue): smtp-relay.brevo.com / 587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu@correo.com
SMTP_PASS=tu_app_password

# Remitente que aparece en el correo
SMTP_FROM=Inmovisoft <noreply@inmovisoft.mx>

# Dirección donde llegan las solicitudes de demo
CONTACT_EMAIL=ventas@inmovisoft.mx

# Registry privado — credenciales para docker login y deploy
REGISTRY_HOST=registry.xst.mx
REGISTRY_USER=
REGISTRY_PASS=
# Tag de imagen (default: latest). Se puede pasar como argumento a deploy.sh
IMAGE_TAG=latest
